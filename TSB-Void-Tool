-- Colors
local rainbowColors = {
	Color3.fromRGB(255, 0, 0),
	Color3.fromRGB(255, 127, 0),
	Color3.fromRGB(255, 255, 0),
	Color3.fromRGB(0, 255, 0),
	Color3.fromRGB(0, 255, 255),
	Color3.fromRGB(0, 0, 255),
	Color3.fromRGB(139, 0, 255)
}

local backgroundColors = {
	Color3.fromRGB(0, 0, 0),
	Color3.fromRGB(35, 35, 35),
	Color3.fromRGB(60, 60, 60),
	Color3.fromRGB(25, 25, 25)
}

-- Rainbow functions
local function rainbowTweenText(obj)
	task.spawn(function()
		while obj and obj.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(obj, TweenInfo.new(0.4), {TextColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

local function backgroundTween(obj)
	task.spawn(function()
		while obj and obj.Parent do
			for _, color in ipairs(backgroundColors) do
				local tween = TweenService:Create(obj, TweenInfo.new(0.8), {BackgroundColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

-- Platform
local function createPlatform(position)
	local part = Instance.new("Part")
	part.Size = platformSize
	part.Position = position
	part.Anchored = true
	part.Material = Enum.Material.SmoothPlastic
	part.Transparency = 0.75
	part.Color = Color3.fromRGB(255, 0, 0)
	part.Parent = workspace
	return part
end

local function resetCamera()
	if character and character:FindFirstChild("Humanoid") then
		camera.CameraSubject = character.Humanoid
		camera.CameraType = Enum.CameraType.Custom
	end
end

local function teleportPlayer()
	if character and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.CFrame = CFrame.new(teleportPosition)
	end
end

