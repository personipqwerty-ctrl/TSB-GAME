-- Gray/Black background tween
local function backgroundTween(object)
	task.spawn(function()
		while object and object.Parent do
			for _, color in ipairs(backgroundColors) do
				local tween = TweenService:Create(
					object,
					TweenInfo.new(0.8, Enum.EasingStyle.Sine),
					{BackgroundColor3 = color}
				)

				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

-- Create platform
local function createPlatform(position)
	local newPlatform = Instance.new("Part")
	newPlatform.Name = "ExtremeVoidPlatform"
	newPlatform.Size = platformSize
	newPlatform.Position = position
	newPlatform.Anchored = true

	-- Transparent platform
	newPlatform.Material = Enum.Material.SmoothPlastic
	newPlatform.Transparency = 0.75

	newPlatform.Color = Color3.fromRGB(255, 0, 0)
	newPlatform.Parent = workspace

	rainbowTweenPart(newPlatform)

	return newPlatform
end

-- Reset camera
local function resetCamera()
	if character and character:FindFirstChild("Humanoid") then
		camera.CameraSubject = character.Humanoid
		camera.CameraType = Enum.CameraType.Custom
	end
end

-- Teleport once
local function teleportPlayer()
	if character and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.CFrame = CFrame.new(teleportPosition)
	end
end

