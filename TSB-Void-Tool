-- Rainbow tweens
local function rainbowTweenPart(part)
	task.spawn(function()
		while part and part.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(part, TweenInfo.new(0.4), {Color = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

local function rainbowTweenText(button)
	task.spawn(function()
		while button and button.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(button, TweenInfo.new(0.4), {TextColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

local function rainbowTweenLabel(label)
	task.spawn(function()
		while label and label.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(label, TweenInfo.new(0.4), {TextColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

local function backgroundTween(obj)
	task.spawn(function()
		while obj and obj.Parent do
			for _, color in ipairs(backgroundColors) do
				local tween = TweenService:Create(obj, TweenInfo.new(0.8), {BackgroundColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

-- Platform
local function createPlatform(position)
	local part = Instance.new("Part")
	part.Size = platformSize
	part.Position = position
	part.Anchored = true
	part.Material = Enum.Material.SmoothPlastic
	part.Transparency = 0.75
	part.Color = Color3.fromRGB(255, 0, 0)
	part.Parent = workspace

	rainbowTweenPart(part)
	return part
end

local function resetCamera()
	if character and character:FindFirstChild("Humanoid") then
		camera.CameraSubject = character.Humanoid
		camera.CameraType = Enum.CameraType.Custom
	end
end

local function teleportPlayer()
	if character and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.CFrame = CFrame.new(teleportPosition)
	end
end

