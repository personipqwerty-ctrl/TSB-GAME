button.MouseButton1Click:Connect(function()

	if not toggled then
		savedCF = character.HumanoidRootPart.CFrame
		toggled = true

		platform = Instance.new("Part")
		platform.Size = platformSize
		platform.Position = teleportPosition + Vector3.new(0,-3,0)
		platform.Anchored = true
		platform.Transparency = 0.75
		platform.Material = Enum.Material.SmoothPlastic
		platform.TopSurface = Enum.SurfaceType.Smooth
		platform.BottomSurface = Enum.SurfaceType.Smooth
		platform.Parent = workspace

		rainbowCycle(platform, "Part")

		character.HumanoidRootPart.CFrame = CFrame.new(teleportPosition)
		button.Text = "Void: ON"
	else
		toggled = false

		if platform then
			platform:Destroy()
			platform = nil
		end

		if savedCF then
			character.HumanoidRootPart.CFrame = savedCF
		end

		button.Text = "Void: OFF"
	end
end)
