end)

-- Rainbow tween for platform
local function rainbowTweenPart(part)
	task.spawn(function()
		while part and part.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(
					part,
					TweenInfo.new(0.4, Enum.EasingStyle.Linear),
					{Color = color}
				)

				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

-- Rainbow tween for button text
local function rainbowTweenText(button)
	task.spawn(function()
		while button and button.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(
					button,
					TweenInfo.new(0.4, Enum.EasingStyle.Linear),
					{TextColor3 = color}
				)

				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

