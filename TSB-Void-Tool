---------------------------------------------------
-- 🌈 RAINBOW CYCLER
---------------------------------------------------
local function rainbowCycle(obj, mode)
	task.spawn(function()
		local hue = 0

		while obj and obj.Parent do
			hue = (hue + 0.01) % 1
			local color = Color3.fromHSV(hue, 1, 1)

			if mode == "Text" then
				obj.TextColor3 = color
			else
				obj.Color = color
			end

			RunService.Heartbeat:Wait()
		end
	end)
end

