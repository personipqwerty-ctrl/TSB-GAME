-- ✅ FIXED EXECUTE ANIMATION (LEFT/RIGHT SLIDE OUT)
executeButton.MouseButton1Click:Connect(function()
	local startPos = frame.Position

	local wobbleTime = 0.35
	local startTime = tick()

	local conn
	conn = RunService.RenderStepped:Connect(function()
		local t = tick() - startTime

		-- wobble left/right first
		local wobble = math.sin(t * 18) * 25

		frame.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + wobble,
			startPos.Y.Scale,
			startPos.Y.Offset
		)

		if t >= wobbleTime then
			conn:Disconnect()

			-- slide OUT to right
			local outTween = TweenService:Create(frame, TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {
				Position = UDim2.new(1.5, 0, startPos.Y.Scale, startPos.Y.Offset)
			})

			outTween:Play()
			outTween.Completed:Wait()

			frame.Visible = false
			button.Visible = true
		end
	end)
end)

-- VOID TOGGLE
button.MouseButton1Click:Connect(function()
	local originalSize = button.Size

	local squish = TweenService:Create(button, TweenInfo.new(0.08), {
		Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset - 10, originalSize.Y.Scale, originalSize.Y.Offset - 5)
	})

	local unsquish = TweenService:Create(button, TweenInfo.new(0.12), {
		Size = originalSize
	})

	squish:Play()
	squish.Completed:Wait()
	unsquish:Play()

	if not character or not character:FindFirstChild("HumanoidRootPart") then return end

	if not toggled then
		savedPosition = character.HumanoidRootPart.CFrame
	end

	toggled = not toggled

	if toggled then
		platform = createPlatform(teleportPosition + Vector3.new(0, -3, 0))
		teleportPlayer()
		button.Text = "Void: ON"
	else
		if platform then
			platform:Destroy()
			platform = nil
		end

		if savedPosition then
			character.HumanoidRootPart.CFrame = savedPosition
		end

		button.Text = "Void: OFF"
		resetCamera()
	end
end)
