local camera = workspace.CurrentCamera

local savedPosition = nil
local toggled = false
local platform = nil

-- LOW HEALTH
local lowHealthTriggered = false

local function setupHealthCheck(char)
	local humanoid = char:WaitForChild("Humanoid")
	lowHealthTriggered = false

	humanoid.HealthChanged:Connect(function(health)
		if health <= 20 and not lowHealthTriggered then
			lowHealthTriggered = true

			game.StarterGui:SetCore("SendNotification", {
				Title = "Critical Low Health",
				Text = "Low Health! Go Void Now!",
				Duration = 5,
				Icon = "rbxassetid://1764960415"
			})
		end

		if health > 20 then
			lowHealthTriggered = false
		end
	end)
end

-- Colors
local rainbowColors = {
	Color3.fromRGB(255, 0, 0),
	Color3.fromRGB(255, 127, 0),
	Color3.fromRGB(255, 255, 0),
	Color3.fromRGB(0, 255, 0),
	Color3.fromRGB(0, 255, 255),
	Color3.fromRGB(0, 0, 255),
	Color3.fromRGB(139, 0, 255)
}

local backgroundColors = {
	Color3.fromRGB(0, 0, 0),
	Color3.fromRGB(35, 35, 35),
	Color3.fromRGB(60, 60, 60),
	Color3.fromRGB(25, 25, 25)
}

-- Character setup
local function setupCharacter(char)
	character = char
	wait(1)

	camera.CameraSubject = character:WaitForChild("Humanoid")
	camera.CameraType = Enum.CameraType.Custom

	setupHealthCheck(character)
end

player.CharacterAdded:Connect(setupCharacter)
setupCharacter(character)

-- Rainbow
local function rainbowTweenText(obj)
	task.spawn(function()
		while obj and obj.Parent do
			for _, color in ipairs(rainbowColors) do
				local tween = TweenService:Create(obj, TweenInfo.new(0.4), {TextColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

local function backgroundTween(obj)
	task.spawn(function()
		while obj and obj.Parent do
			for _, color in ipairs(backgroundColors) do
				local tween = TweenService:Create(obj, TweenInfo.new(0.8), {BackgroundColor3 = color})
				tween:Play()
				tween.Completed:Wait()
			end
		end
	end)
end

-- Platform
local function createPlatform(position)
	local part = Instance.new("Part")
	part.Size = platformSize
	part.Position = position
	part.Anchored = true
	part.Material = Enum.Material.SmoothPlastic
	part.Transparency = 0.75
	part.Color = Color3.fromRGB(255, 0, 0)
	part.Parent = workspace
	return part
end

local function resetCamera()
	if character and character:FindFirstChild("Humanoid") then
		camera.CameraSubject = character.Humanoid
		camera.CameraType = Enum.CameraType.Custom
	end
end

local function teleportPlayer()
	if character and character:FindFirstChild("HumanoidRootPart") then
		character.HumanoidRootPart.CFrame = CFrame.new(teleportPosition)
	end
end

